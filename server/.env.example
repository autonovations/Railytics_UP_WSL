# ==============================================
# RAILYTICS API - ENVIRONMENT CONFIGURATION
# ==============================================

# === SERVER CONFIGURATION ===
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
LOG_LEVEL=INFO

# === MONGODB CONFIGURATION ===
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=Railytics
MONGO_FRAMES_COLLECTION=frames
MONGO_STREAMS_COLLECTION=streams
MONGO_EVENTS_COLLECTION=railway_events

# === YOLO MODEL CONFIGURATION ===
YOLO_MODEL_PATH=yolov8n.pt
YOLO_TARGET_LABELS=train,locomotive
YOLO_CONFIDENCE_THRESHOLD=0.5

# === STORAGE CONFIGURATION ===
TRAINS_FOLDER=frames_with_trains
EVENT_VIDEOS_FOLDER=event_videos

# === CAPTURE CONFIGURATION ===
CAPTURE_INTERVAL_SECONDS=1
EVENT_INACTIVITY_WINDOW_SECONDS=12

# === CORS CONFIGURATION ===
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
